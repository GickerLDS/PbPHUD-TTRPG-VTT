{
  "name": "pbphud-map-node-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/check-node-version.cjs",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "prebuild": "node scripts/check-node-version.cjs",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "prestart": "node scripts/check-node-version.cjs",
    "start": "node server/index.js",
    "prestart:prod": "node scripts/check-node-version.cjs",
    "start:prod": "cross-env NODE_ENV=production node server/index.js",
    "predb:migrate": "node scripts/check-node-version.cjs",
    "db:migrate": "node server/db/migrate.js",
    "pretest": "node scripts/check-node-version.cjs",
    "test": "node --test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mariadb": "^3.4.0",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.1",
    "nodemon": "^3.1.14",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
