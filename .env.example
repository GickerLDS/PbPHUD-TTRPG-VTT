NODE_ENV=development
PORT=3001

# Development React/Vite server. Use CLIENT_ORIGIN for a public custom domain
# such as https://maps.example.com; otherwise it is built from these values.
CLIENT_HOST=127.0.0.1
CLIENT_PORT=5173
# CLIENT_ORIGIN=http://127.0.0.1:5173

# Backend origin used in logs and by Vite's dev proxy.
API_HOST=127.0.0.1
# API_ORIGIN=http://127.0.0.1:3001

# MariaDB connection used by the new Node app only.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pbphud_map
DB_PASSWORD=change-me
DB_NAME=pbphud_maps
DB_CONNECTION_LIMIT=10

# Tile image directory served read-only by the Node app.
# Relative paths are resolved from map-node-app/.
TILE_ASSET_DIR=assets/tiles

# Comma-separated origins allowed to call the API during development.
# Defaults to CLIENT_ORIGIN plus localhost on CLIENT_PORT when unset.
# CORS_ORIGINS=https://maps.example.com,https://admin.example.com

# Shared bearer token for server-to-server Chummer imports.
# Chummer should send: Authorization: Bearer <this value>
PBPHUD_INTEGRATION_TOKEN=change-me-long-random-secret

# Account registration/sign-in.
AUTH_SESSION_DAYS=14
AUTH_EMAIL_VERIFICATION_HOURS=24

# Google reCAPTCHA v3 score-based registration check.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_TYPE=v3
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ACTION=register
REQUIRE_RECAPTCHA=false

# SMTP2GO email verification.
MAIL_FROM="PBPHud VTT <no-reply@example.com>"
CONTACT_TO_EMAIL=contact@example.com
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
