NODE_ENV=development
PORT=3001

# MariaDB connection used by the new Node app only.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pbphud_map
DB_PASSWORD=change-me
DB_NAME=pbphud_maps
DB_CONNECTION_LIMIT=10

# Tile image directory served read-only by the Node app.
# Relative paths are resolved from map-node-app/.
TILE_ASSET_DIR=assets/tiles

# Comma-separated origins allowed to call the API during development.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
